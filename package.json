{
  "name": "taskpack",
  "version": "0.1.0",
  "description": "Task workspaces on disk — write prompts in files, never lose context again.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "taskpack": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "prompt",
    "cli",
    "task",
    "workspace",
    "context",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
